{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/dhk/skill-map/blob/main/schemas/wiring.schema.json",
  "title": "WIRING.md",
  "description": "Schema for WIRING.md — inter-skill integration declarations. Version 0.1.",
  "type": "object",
  "required": ["spec", "type", "name", "description"],
  "properties": {
    "spec": {
      "type": "string",
      "const": "0.1",
      "description": "Spec version. Must be '0.1'."
    },
    "type": {
      "type": "string",
      "enum": ["router", "workflow", "ensemble"],
      "description": "Integration archetype."
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Slug identifier. Lowercase, hyphens only."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "One sentence: what this wiring does and when to use it."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier (e.g. MIT, Apache-2.0)."
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "router" } } },
      "then": {
        "required": ["entry", "routes"],
        "properties": {
          "entry": {
            "type": "string",
            "description": "Skill that performs the routing."
          },
          "routes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["trigger"],
              "properties": {
                "trigger": {
                  "type": "string",
                  "description": "Intent pattern that activates this route."
                },
                "skill": {
                  "type": "string",
                  "description": "Single skill to invoke."
                },
                "skills": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Multiple skills to invoke."
                },
                "mode": {
                  "type": "string",
                  "enum": ["sequential", "parallel"],
                  "default": "sequential"
                },
                "repo": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$",
                  "description": "owner/repo for external skills."
                }
              },
              "oneOf": [
                { "required": ["skill"] },
                { "required": ["skills"] }
              ]
            }
          },
          "context": {
            "type": "object",
            "properties": {
              "requires_file": { "type": "string" },
              "missing_action": { "type": "string" }
            }
          },
          "synthesis": {
            "type": "string",
            "description": "How to combine outputs from parallel routes."
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "workflow" } } },
      "then": {
        "required": ["steps"],
        "properties": {
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "skill"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9-]*$",
                  "description": "Unique slug within this workflow."
                },
                "skill": {
                  "type": "string",
                  "description": "Skill to invoke at this step."
                },
                "repo": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$",
                  "description": "owner/repo for external skills."
                },
                "description": { "type": "string" },
                "requires": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "IDs of steps that must complete first."
                },
                "input": {
                  "type": "string",
                  "description": "What this step consumes from prior steps."
                },
                "output": {
                  "type": "string",
                  "description": "What this step produces."
                },
                "guard": {
                  "type": "object",
                  "required": ["type"],
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": ["confirmation", "dry_run", "condition"]
                    },
                    "prompt": { "type": "string" },
                    "flag": { "type": "string" },
                    "check": { "type": "string" }
                  }
                },
                "on_failure": { "type": "string" }
              }
            }
          },
          "on_failure": {
            "type": "string",
            "description": "Default failure behavior for all steps."
          }
        }
      }
    },
    {
      "if": { "properties": { "type": { "const": "ensemble" } } },
      "then": {
        "required": ["members"],
        "properties": {
          "entry": {
            "type": "string",
            "description": "Coordinator skill (must be in members)."
          },
          "members": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["skill"],
              "properties": {
                "skill": { "type": "string" },
                "repo": {
                  "type": "string",
                  "pattern": "^[a-zA-Z0-9_-]+/[a-zA-Z0-9_.-]+$"
                },
                "role": {
                  "type": "string",
                  "description": "What this member does within the ensemble."
                },
                "optional": {
                  "type": "boolean",
                  "default": false
                }
              }
            }
          },
          "install": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string",
                "enum": ["symlink", "copy", "plugin"]
              },
              "target": { "type": "string" },
              "source": { "type": "string" }
            }
          }
        }
      }
    }
  ]
}
